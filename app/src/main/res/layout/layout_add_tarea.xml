<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@drawable/rounded_bottom_sheet">

    <EditText
        android:id="@+id/etNuevoTitulo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="¿Qué tienes pendiente?"
        android:background="@null"
        android:textSize="18sp"
        android:importantForAutofill="no"
        android:inputType="textCapSentences" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="20dp">

        <!-- Botón para Asignatura -->
        <Button
            android:id="@+id/btnSeleccionarAsignatura"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Asignatura"
            android:drawableStart="@android:drawable/ic_menu_agenda"
            android:textAllCaps="false" />

        <!-- Botón para Fecha -->
        <Button
            android:id="@+id/btnSeleccionarFecha"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Fecha"
            android:drawableStart="@android:drawable/ic_menu_my_calendar"
            android:textAllCaps="false" />
    </LinearLayout>

    <Button
        android:id="@+id/btnGuardarTarea"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Guardar"
        android:layout_marginTop="16dp"
        android:backgroundTint="#4285F4"
        android:textColor="#FFFFFF" />

</LinearLayout>